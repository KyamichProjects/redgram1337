{
  "name": "redgram",
  "private": true,
  "version": "1.0.0",
  "description": "RedGram Desktop App",
  "author": "StepGuest",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "server": "node server.js",
    "start": "electron .",
    "dist": "set CSC_LINK=null && electron-builder --win"
  },
  "dependencies": {
    "@google/genai": "latest",
    "express": "^4.18.2",
    "lucide-react": "^0.344.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "sqlite": "^5.1.1",
    "sqlite3": "^5.1.7",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.56",
    "@types/react-dom": "^18.2.19",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "postcss": "^8.4.35",
    "tailwindcss": "^3.4.1",
    "typescript": "^5.2.2",
    "vite": "^5.1.4"
  },
  "build": {
    "appId": "com.redgram.app",
    "productName": "RedGram",
    "win": {
      "target": "portable",
      "icon": "icon.ico",
      "cscLink": null
    },
    "protocols": {
      "name": "redgram-protocol",
      "schemes": [
        "redgram"
      ]
    }
  }
}